# Environment Variables for Federation Gateway UI

# API Base URL
# Point this to your OpenID Federation Admin API backend
# Default: http://localhost:8765 (reference FastAPI backend)
# Production: Set to your backend URL
VITE_API_BASE_URL=http://localhost:8765

# Examples for different deployment scenarios:
# VITE_API_BASE_URL=https://api.federation.example.org
# VITE_API_BASE_URL=https://oidfed-backend.cloud.edu/v1
# VITE_API_BASE_URL=http://localhost:9000  # Custom port

# Optional: Multi-backend switcher configuration (JSON array)
# If provided, UI lets operators switch backend pods/instances at runtime.
# Example:
# VITE_BACKENDS_JSON=[{"id":"pod-a","name":"Admin API A","baseUrl":"http://localhost:8765"},{"id":"pod-b","name":"Admin API B","baseUrl":"http://localhost:9865"}]
